<aside data-testid="app-sidebar"
       class="hidden md:flex fixed left-0 top-0 z-40 h-screen w-64 flex-col border-r border-outline-variant bg-[linear-gradient(180deg,var(--color-surface-container-lowest)_0%,var(--color-surface-container-low)_38%,var(--color-surface-container-low)_100%)] shadow-[6px_0_36px_-14px_rgba(0,31,81,0.14)]">
  <div class="shrink-0 px-margin pb-sm pt-margin">
    <% if Current.effective_logo_url.present? %>
      <img src="<%= Current.effective_logo_url %>" alt="<%= Current.effective_organization&.name %>" class="h-10 w-auto max-w-[180px] object-contain drop-shadow-[0_1px_2px_rgba(0,31,81,0.06)]">
    <% else %>
      <div class="text-headline-md font-semibold tracking-tight text-primary"><%= Current.effective_organization&.name || "SolarIQ+" %></div>
    <% end %>
  </div>

  <div class="shrink-0 px-margin pb-3">
    <div data-testid="brand-accent-stripe" class="sidebar-brand-accent-stripe" aria-hidden="true"></div>
    <div class="mt-3 h-px bg-gradient-to-r from-transparent via-outline-variant to-transparent opacity-90" aria-hidden="true"></div>
  </div>

  <nav class="min-h-0 flex-1 overflow-y-auto px-3 py-2" aria-label="Primary">
    <ul class="space-y-1">
      <% nav_items.each do |item| %>
        <% active = current_page?(item[:path]) %>
        <li>
          <%= link_to item[:path],
                      class: [
                        "relative flex items-center gap-sm rounded-lg px-md py-2.5 text-label-md transition-colors duration-150",
                        active ? "sidebar-nav-link--active bg-primary-fixed text-on-primary-fixed-variant shadow-[inset_0_0_0_1px_rgba(0,31,81,0.06),0_1px_2px_rgba(0,31,81,0.04)] before:absolute before:left-1.5 before:top-1/2 before:h-[60%] before:w-[3px] before:-translate-y-1/2 before:rounded-full before:bg-solar-accent before:content-[''] before:shadow-[0_0_10px_rgba(240,133,41,0.45)]" : "text-on-surface hover:bg-surface-container hover:shadow-sm"
                      ].join(" ") do %>
            <span class="material-symbols-outlined text-[22px] leading-none opacity-90"><%= item[:icon] %></span>
            <span class="font-medium tracking-[0.01em]"><%= item[:label] %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </nav>

  <div class="shrink-0 border-t border-outline-variant bg-surface-container-lowest/60 px-margin py-sm backdrop-blur-[2px]">
    <div class="flex items-center gap-sm">
      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary text-on-primary text-label-sm font-semibold shadow-[0_2px_8px_rgba(0,31,81,0.2)]">
        <%= nav_account_scope_initial %>
      </div>
      <div class="min-w-0 flex-1">
        <div class="break-words text-label-md font-medium leading-snug text-on-surface"><%= nav_account_scope_name %></div>
      </div>
      <%= button_to destroy_user_session_path,
                    method: :delete,
                    class: "group inline-flex shrink-0 items-center justify-center rounded-md p-2 text-on-surface-variant transition-colors hover:bg-surface-container/50 hover:text-on-surface focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary",
                    form: { class: "m-0 inline-flex shrink-0" },
                    aria: { label: "Sign out" } do %>
        <span class="material-symbols-outlined text-[20px] leading-none opacity-80 transition-opacity group-hover:opacity-100" aria-hidden="true">logout</span>
      <% end %>
    </div>
  </div>
</aside>
