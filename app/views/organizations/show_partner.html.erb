<% provide(:title, "#{@target.name} — Customers") %>

<%
  actions = capture do
    concat(link_to "← Back to Partners", dashboard_path,
           class: "px-md py-sm rounded-md border border-outline text-on-surface text-label-md hover:bg-surface-container")
  end
%>

<%= render "shared/page_header",
           title: @target.name,
           subtitle: "Partner — #{@customer_summaries.size} Customers",
           actions: actions %>

<% if @customer_summaries.empty? %>
  <div class="bg-surface-container-low border border-outline-variant rounded-lg p-xl text-center text-on-surface-variant">
    No Customers under <%= @target.name %> yet.
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-md">
    <% @customer_summaries.each do |s| %>
      <%= link_to organization_path(s[:org]), class: "block bg-surface-container-lowest rounded-lg border border-outline-variant p-md hover:border-primary transition-colors" do %>
        <div class="flex items-center justify-between mb-md">
          <h3 class="text-headline-md text-on-surface"><%= s[:org].name %></h3>
          <% if s[:critical] > 0 %>
            <span class="px-sm py-1 rounded-full bg-error-container text-on-error-container text-label-sm"><%= s[:critical] %> critical/24h</span>
          <% else %>
            <span class="px-sm py-1 rounded-full bg-primary-fixed text-on-primary-fixed-variant text-label-sm">healthy</span>
          <% end %>
        </div>
        <dl class="grid grid-cols-2 gap-sm text-center">
          <div>
            <dt class="text-label-sm text-on-surface-variant uppercase">Sites</dt>
            <dd class="text-headline-md mt-xs"><%= s[:site_count] %></dd>
          </div>
          <div>
            <dt class="text-label-sm text-on-surface-variant uppercase">Open cases</dt>
            <dd class="text-headline-md mt-xs"><%= s[:open_cases] %></dd>
          </div>
        </dl>
      <% end %>
    <% end %>
  </div>
<% end %>
