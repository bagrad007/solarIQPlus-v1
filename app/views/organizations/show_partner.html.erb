<% provide(:title, "#{@target.name} — Customers") %>

<%
  actions = capture do
    concat(link_to "← Back to Partners", dashboard_path,
           class: "px-md py-sm rounded-md border border-outline text-on-surface text-label-md hover:bg-surface-container")
  end
%>

<%= render "shared/page_header",
           title: @target.name,
           subtitle: "Partner — #{@customer_summaries.size} Customers",
           actions: actions %>

<% if @customer_summaries.empty? %>
  <div class="bg-surface-container-low border border-outline-variant rounded-lg p-xl text-center text-on-surface-variant">
    No Customers under <%= @target.name %> yet.
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 2xl:grid-cols-3 gap-lg">
    <% @customer_summaries.each do |s| %>
      <%= link_to organization_path(s[:org]), class: "block h-full min-h-0 bg-surface-container-lowest rounded-lg border border-outline-variant p-lg hover:border-primary transition-colors" do %>
        <%= render "shared/card_title_and_status", title: s[:org].name do %>
          <% if s[:critical] > 0 %>
            <span class="inline-flex items-center whitespace-nowrap px-sm py-1 rounded-full bg-error-container text-on-error-container text-label-sm"><%= s[:critical] %> critical/24h</span>
          <% else %>
            <span class="inline-flex items-center whitespace-nowrap px-sm py-1 rounded-full bg-primary-fixed text-on-primary-fixed-variant text-label-sm">healthy</span>
          <% end %>
        <% end %>
        <dl class="grid grid-cols-2 gap-x-md gap-y-sm text-center min-w-0">
          <div>
            <dt class="text-label-sm text-on-surface-variant uppercase">Sites</dt>
            <dd class="text-headline-md mt-xs"><%= s[:site_count] %></dd>
          </div>
          <div>
            <dt class="text-label-sm text-on-surface-variant uppercase">Open cases</dt>
            <dd class="text-headline-md mt-xs"><%= s[:open_cases] %></dd>
          </div>
        </dl>
      <% end %>
    <% end %>
  </div>
<% end %>
