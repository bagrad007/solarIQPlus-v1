<% provide(:title, "#{@target.name} — Sites") %>

<%
  actions = capture do
    concat(link_to "← Back", :back,
           class: "px-md py-sm rounded-md border border-outline text-on-surface text-label-md hover:bg-surface-container")
  end
%>

<%= render "shared/page_header",
           title: @target.name,
           subtitle: "Customer — #{@site_summaries.size} Sites",
           actions: actions %>

<% if @site_summaries.empty? %>
  <div class="bg-surface-container-low border border-outline-variant rounded-lg p-xl text-center text-on-surface-variant">
    No Sites yet.
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 2xl:grid-cols-3 gap-lg">
    <% @site_summaries.each do |s| %>
      <%# Stretched-link card: outer surface clicks navigate to the Site
          dashboard, while the corner Edit Site link sits above the stretched
          link via z-10 so anchor nesting stays valid. %>
      <div class="group relative flex h-full min-h-0 flex-col bg-surface-container-lowest rounded-lg border border-outline-variant p-lg hover:border-primary transition-colors">
        <%= link_to "", site_path(s[:site]),
                    class: "absolute inset-0 rounded-lg",
                    aria: { label: s[:site].name } %>

        <%= render "shared/card_title_and_status", title: s[:site].name do %>
          <% case s[:latest]&.alarm_state %>
          <% when "critical" %>
            <span class="inline-flex items-center whitespace-nowrap px-sm py-1 rounded-full bg-error-container text-on-error-container text-label-sm">critical</span>
          <% when "warn" %>
            <span class="inline-flex items-center whitespace-nowrap px-sm py-1 rounded-full bg-secondary-container text-on-secondary-container text-label-sm">warn</span>
          <% when "normal" %>
            <span class="inline-flex items-center whitespace-nowrap px-sm py-1 rounded-full bg-primary-fixed text-on-primary-fixed-variant text-label-sm">normal</span>
          <% else %>
            <span class="inline-flex items-center whitespace-nowrap px-sm py-1 rounded-full bg-surface-container-high text-on-surface-variant text-label-sm">no data</span>
          <% end %>
        <% end %>
        <% if s[:latest] %>
          <p class="text-label-sm text-on-surface-variant">
            Last reading <%= time_ago_in_words(s[:latest].recorded_at) %> ago
          </p>
        <% end %>

        <% unless Current.in_view_as? %>
          <div class="mt-auto pt-md flex justify-end">
            <%= link_to "Edit Site", edit_site_path(s[:site]),
                        class: "relative z-10 inline-flex items-center gap-xs rounded-md border border-outline-variant bg-surface-container-lowest px-sm py-1 text-label-sm text-on-surface hover:bg-surface-container",
                        aria: { label: "Edit #{s[:site].name}" } %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%= render "shared/ai_energy_analyst_widget", context_label: customer_scope_label if customer_scope_present? %>
