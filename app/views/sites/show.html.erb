<% provide(:title, "#{@site.name} — Operational Dashboard") %>

<%
  actions = capture do
    unless Current.in_view_as?
      concat(link_to "New Case", new_site_case_path(@site),
             class: "px-md py-sm rounded-md bg-primary text-on-primary text-label-md hover:opacity-90 inline-flex items-center gap-xs me-sm")
      concat(link_to "Edit Site", edit_site_path(@site),
             class: "px-md py-sm rounded-md border border-outline text-on-surface text-label-md hover:bg-surface-container")
    end
  end
%>

<%= render "shared/page_header",
           title: @site.name,
           subtitle: "Operational dashboard",
           actions: actions %>

<% latest_payload = (@latest&.metric_payload || {}).with_indifferent_access %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-md mb-margin">
  <div class="bg-surface-container-lowest rounded-lg border border-outline-variant p-md">
    <div class="text-label-sm text-on-surface-variant uppercase">Generation now</div>
    <div class="text-display-lg text-primary mt-xs">
      <%= number_with_delimiter(latest_payload[:power_kw].to_f.round(1)) %><span class="text-headline-md text-on-surface-variant ml-xs">kW</span>
    </div>
    <p class="text-label-sm text-on-surface-variant mt-sm">
      Capacity factor: <%= (latest_payload[:capacity_factor].to_f * 100).round(1) %>%
    </p>
  </div>

  <div class="bg-surface-container-lowest rounded-lg border border-outline-variant p-md">
    <div class="text-label-sm text-on-surface-variant uppercase">Alarm state</div>
    <% case @latest&.alarm_state %>
    <% when "critical" %>
      <div class="text-headline-lg text-error mt-xs">Critical</div>
    <% when "warn" %>
      <div class="text-headline-lg text-secondary mt-xs">Warning</div>
    <% when "normal" %>
      <div class="text-headline-lg text-primary mt-xs">Normal</div>
    <% else %>
      <div class="text-headline-lg text-on-surface-variant mt-xs">No data</div>
    <% end %>
    <p class="text-label-sm text-on-surface-variant mt-sm">
      <% if @latest %>
        Last reading <%= time_ago_in_words(@latest.recorded_at) %> ago
      <% else %>
        Awaiting first reading
      <% end %>
    </p>
  </div>

  <div class="bg-surface-container-lowest rounded-lg border border-outline-variant p-md">
    <div class="text-label-sm text-on-surface-variant uppercase">Site Asset Parameters</div>
    <dl class="text-label-md mt-sm space-y-xs">
      <div class="flex justify-between"><dt class="text-on-surface-variant">Inverter</dt><dd><%= latest_payload[:inverter_status] || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-on-surface-variant">String voltage</dt><dd><%= latest_payload[:string_voltage] %> V</dd></div>
      <div class="flex justify-between"><dt class="text-on-surface-variant">Ambient temp</dt><dd><%= latest_payload[:ambient_temp_c] %> °C</dd></div>
      <div class="flex justify-between"><dt class="text-on-surface-variant">Polling</dt><dd><%= @site.polling_interval_seconds %> s</dd></div>
    </dl>
  </div>
</div>

<div class="bg-surface-container-lowest rounded-lg border border-outline-variant p-md mb-margin">
  <h2 class="text-headline-md mb-sm">Generation — last 48 readings</h2>
  <%= render "shared/sparkline", values: @recent.map { |t| (t.metric_payload["power_kw"] || 0).to_f }.reverse %>
  <p class="text-label-sm text-on-surface-variant mt-sm">
    Live charting wires up in Plan B (React diagnostics island). Plan A renders the latest readings as a static sparkline placeholder.
  </p>
</div>

<div class="bg-surface-container-lowest rounded-lg border border-outline-variant p-md">
  <div class="flex items-center justify-between mb-sm">
    <h2 class="text-headline-md">Open cases on this site</h2>
    <%= link_to "All cases", site_cases_path(@site), class: "text-label-md text-primary hover:underline" if false %>
  </div>
  <% if @open_cases.empty? %>
    <p class="text-label-md text-on-surface-variant">No open cases on this site.</p>
  <% else %>
    <ul class="divide-y divide-outline-variant">
      <% @open_cases.each do |c| %>
        <li class="py-sm">
          <%= link_to c.subject, case_path(c), class: "text-label-md text-primary hover:underline" %>
          <span class="text-label-sm text-on-surface-variant ml-sm">[<%= c.status %>]</span>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>

<%= render "shared/ai_energy_analyst_widget", context_label: customer_scope_label if customer_scope_present? %>
