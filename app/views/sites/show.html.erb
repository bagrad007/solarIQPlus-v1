<% provide(:title, "#{@site.name} — Operational Dashboard") %>

<% content_for :head do %>
  <%= javascript_include_tag "dashboard", "data-turbo-track": "reload", type: "module", defer: true %>
<% end %>

<%# Per-site write CTAs (Edit Site, New Case) used to sit in this header.
    Edit Site moved to a corner link on each Site card on the listing pages
    so the action lives next to the asset; per-site New Case is dropped as
    redundant — global case creation is reachable from the Cases index and
    Partner dashboards. %>
<%
  firing_count = @firing_alarms_count.to_i
  badge_variant = firing_count.zero? ? "quiet" : "active"
%>

<%= render "shared/page_header",
           title: @site.name,
           subtitle: "Operational dashboard",
           actions: link_to(alarms_path(site_id: @site.id, status: ["firing"]),
                            class: "alarm-badge alarm-badge--#{badge_variant}",
                            data: { testid: "site-firing-alarms-badge" }) {
             tag.span("notifications_active", class: "material-symbols-outlined", "aria-hidden": true) +
             tag.span(pluralize(firing_count, "firing alarm"))
           } %>

<% dashboard_payload = @summary.merge(forecast: @forecast) %>

<div class="mb-margin flex w-full min-w-0 max-w-full flex-col gap-lg">
  <%# Full-width summary row (two cards side-by-side from md), then charts in one column below. %>
  <div class="w-full min-w-0" role="complementary" aria-label="Generation context">
    <%= render "dashboard_sidebar_column", summary: @summary, forecast: @forecast %>
  </div>
  <div class="block w-full min-h-0 min-w-0"
       data-dashboard-mount
       data-payload="<%= dashboard_payload.to_json %>">
    <noscript>
      <p class="text-label-md text-on-surface-variant italic">
        Live charts require JavaScript. The summary cards above remain accurate.
      </p>
    </noscript>
  </div>

<%# ---- Forecast tiles (ERB) — remain readable without JS ---- %>
  <section class="grid grid-cols-1 sm:grid-cols-2 gap-md"
           aria-label="Forecast solar production">
  <%= render "forecast_tile",
             label:         "Forecast Solar Production Today",
             projected_kwh: @forecast[:today_kwh],
             condition:     @forecast[:today_condition],
             high_f:        @forecast[:today_temp_high_f] %>
  <%= render "forecast_tile",
             label:         "Forecast Solar Production Tomorrow",
             projected_kwh: @forecast[:tomorrow_kwh],
             condition:     @forecast[:tomorrow_condition],
             high_f:        @forecast[:tomorrow_temp_high_f] %>
  </section>

<%# ---- Open cases ---- %>
<div class="bg-surface-container-lowest rounded-xl border border-outline-variant p-md shadow-sm">
  <div class="flex items-center justify-between mb-sm">
    <h2 class="text-headline-md">Open cases on this site</h2>
  </div>
  <% if @open_cases.empty? %>
    <p class="text-label-md text-on-surface-variant">No open cases on this site.</p>
  <% else %>
    <ul class="divide-y divide-outline-variant">
      <% @open_cases.each do |c| %>
        <li class="py-sm">
          <%= link_to c.subject, case_path(c), class: "text-label-md text-primary hover:underline" %>
          <span class="text-label-sm text-on-surface-variant ml-sm">[<%= c.status %>]</span>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>

</div>

<%= render "shared/ai_energy_analyst_widget", context_label: customer_scope_label if customer_scope_present? %>
