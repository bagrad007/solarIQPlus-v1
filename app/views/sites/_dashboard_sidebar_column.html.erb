<%#
  Site dashboard summary strip: system status, ambient/forecast (under status),
  and asset lifetime. Two columns from md; first column stacks status + ambient.
  Locals: summary (SiteOperationalSummary#to_h), forecast (SiteForecast#to_h).
%>
<%
  forecast = local_assigns[:forecast] || {}
  totals = summary[:totals] || {}
  latest = summary[:latest] || {}
  today  = summary[:today] || {}
  alarm  = (latest[:alarm_state].presence || "").to_s.downcase
  alarm_label = latest[:alarm_state].to_s.presence&.humanize || "No data"
  last_at = today[:latest_at]
%>
<div class="grid w-full min-w-0 grid-cols-1 items-stretch gap-md md:grid-cols-2">
  <div class="flex h-full min-h-0 min-w-0 flex-col gap-md">
  <section class="min-w-0 rounded-xl border border-outline-variant bg-surface-container-lowest p-md shadow-sm md:flex md:flex-row md:items-center md:justify-between md:gap-lg"
           aria-label="System status">
    <div class="flex min-w-0 flex-col gap-xs">
      <div class="flex items-center justify-between gap-sm">
        <span class="text-label-sm font-semibold uppercase tracking-wider text-on-surface-variant">System status</span>
        <% if alarm == "critical" %>
          <span class="material-symbols-outlined text-error shrink-0 text-[22px]" style="font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24" aria-hidden="true">crisis_alert</span>
        <% elsif alarm == "warn" %>
          <span class="material-symbols-outlined text-secondary shrink-0 text-[22px]" style="font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24" aria-hidden="true">warning</span>
        <% elsif alarm == "normal" %>
          <span class="material-symbols-outlined text-primary shrink-0 text-[22px]" style="font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24" aria-hidden="true">verified</span>
        <% else %>
          <span class="material-symbols-outlined text-on-surface-variant shrink-0 text-[22px]" aria-hidden="true">monitor_heart</span>
        <% end %>
      </div>
      <p class="font-[family-name:var(--font-display-serif)] text-headline-md text-on-surface tracking-tight leading-tight">
        <%= alarm_label %>
      </p>
    </div>
    <dl class="mt-sm grid gap-y-1 text-label-sm border-t border-outline-variant/60 pt-sm md:mt-0 md:w-auto md:shrink-0 md:border-t-0 md:border-l md:border-outline-variant/60 md:pl-md md:pt-0">
      <div class="flex justify-between gap-sm md:flex-col md:items-end md:gap-y-1 md:text-end">
        <dt class="text-on-surface-variant">Last reading</dt>
        <dd class="font-medium text-on-surface md:font-semibold">
          <%= last_at ? "#{time_ago_in_words(last_at)} ago" : "—" %>
        </dd>
      </div>
      <div class="flex justify-between gap-sm md:flex-col md:items-end md:gap-y-1 md:text-end">
        <dt class="text-on-surface-variant">Telemetry link</dt>
        <dd class="font-medium <%= last_at ? "text-primary" : "text-on-surface-variant" %>">
          <%= last_at ? "Stable" : "—" %>
        </dd>
      </div>
    </dl>
  </section>

  <%= render "dashboard_ambient_panel",
             environment: (summary[:environment] || {}),
             forecast: forecast %>

  </div>

  <%
    life_kwh = [totals[:lifetime_kwh].to_f, 0.0].max
    ytd_kwh  = [totals[:ytd_kwh].to_f, 0.0].max
    mtd_kwh  = [totals[:mtd_kwh].to_f, 0.0].max
    mix = life_kwh + ytd_kwh + mtd_kwh
    if mix.positive?
      pct_life = (life_kwh / mix * 100).round(1)
      pct_ytd  = (ytd_kwh / mix * 100).round(1)
      pct_mtd  = (100.0 - pct_life - pct_ytd).round(1)
    else
      pct_life = pct_ytd = 33.3
      pct_mtd  = 33.4
    end
  %>
  <section class="flex h-full min-h-0 min-w-0 flex-col gap-md rounded-xl border border-outline-variant bg-surface-container-lowest p-md shadow-sm"
           aria-label="Asset lifetime generation">
    <h2 class="shrink-0 font-[family-name:var(--font-display-serif)] text-headline-sm tracking-tight text-on-surface">
      Asset lifetime
    </h2>

    <%# Tall flex-grow strip (rectangle) uses space between title and rows; hatched segments in application.tailwind.css %>
    <div
      class="flex min-h-0 max-h-[6.5rem] w-full min-w-0 flex-1 flex-row items-start justify-start overflow-hidden rounded-xl bg-surface-container-highest p-1 leading-[24px] shadow-[inset_0_1px_3px_rgba(0,0,0,0.07)] ring-1 ring-inset ring-outline-variant/40 min-h-[clamp(3.25rem,9vh,5.25rem)] rotate-[720deg]"
      role="img"
      aria-label="<%= "Lifetime #{pct_life} percent, year to date #{pct_ytd} percent, month to date #{pct_mtd} percent of the on-card total scale" %>"
    >
      <div class="asset-lifetime-seg--lifetime h-full min-w-[3px] shrink-0 rounded-l-md" style="width: <%= pct_life %>%"></div>
      <div class="asset-lifetime-seg--ytd h-full min-w-[3px] shrink-0" style="width: <%= pct_ytd %>%"></div>
      <div class="asset-lifetime-seg--mtd h-full min-w-[3px] shrink-0 rounded-r-md" style="width: <%= pct_mtd %>%"></div>
    </div>

    <ul class="min-w-0 shrink-0 divide-y divide-outline-variant/60" role="list">
      <li class="flex items-center gap-md py-md first:pt-0">
        <span class="w-1.5 shrink-0 self-stretch min-h-[2.75rem] rounded-full bg-primary" aria-hidden="true"></span>
        <div class="min-w-0 flex-1 text-label-sm text-on-surface-variant">
          Lifetime generation — <span class="font-semibold tabular-nums text-on-surface"><%= number_with_precision(pct_life, precision: 1, strip_insignificant_zeros: true) %>%</span>
        </div>
        <div class="shrink-0 text-end tabular-nums">
          <span class="text-label-md font-semibold text-on-surface"><%= number_with_delimiter(life_kwh.round(1)) %></span>
          <span class="ms-xs text-label-sm font-medium text-on-surface-variant">kWh</span>
        </div>
      </li>
      <li class="flex items-center gap-md py-md">
        <span class="w-1.5 shrink-0 self-stretch min-h-[2.75rem] rounded-full bg-solar-accent" aria-hidden="true"></span>
        <div class="min-w-0 flex-1 text-label-sm text-on-surface-variant">
          Generation this year — <span class="font-semibold tabular-nums text-on-surface"><%= number_with_precision(pct_ytd, precision: 1, strip_insignificant_zeros: true) %>%</span>
        </div>
        <div class="shrink-0 text-end tabular-nums">
          <span class="text-label-md font-semibold text-on-surface"><%= number_with_delimiter(ytd_kwh.round(1)) %></span>
          <span class="ms-xs text-label-sm font-medium text-on-surface-variant">kWh</span>
        </div>
      </li>
      <li class="flex items-center gap-md py-md last:pb-0">
        <span class="w-1.5 shrink-0 self-stretch min-h-[2.75rem] rounded-full bg-tertiary-container" aria-hidden="true"></span>
        <div class="min-w-0 flex-1 text-label-sm text-on-surface-variant">
          Solar gen this month — <span class="font-semibold tabular-nums text-on-surface"><%= number_with_precision(pct_mtd, precision: 1, strip_insignificant_zeros: true) %>%</span>
        </div>
        <div class="shrink-0 text-end tabular-nums">
          <span class="text-label-md font-semibold text-on-surface"><%= number_with_delimiter(mtd_kwh.round(1)) %></span>
          <span class="ms-xs text-label-sm font-medium text-on-surface-variant">kWh</span>
        </div>
      </li>
    </ul>
  </section>
</div>
