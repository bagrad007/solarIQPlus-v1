<% provide(:title, "Sites — SolarIQ+") %>

<%= render "shared/page_header",
           title: "Sites",
           subtitle: "All Sites visible to you." %>

<% if @sites.empty? %>
  <div class="bg-surface-container-low border border-outline-variant rounded-lg p-xl text-center text-on-surface-variant">
    No Sites visible.
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 2xl:grid-cols-3 gap-lg">
    <% @sites.each do |site| %>
      <%# Stretched-link card: the whole card navigates to site_path, while
          the corner Edit link (z-10) navigates to edit_site_path without
          nesting `<a>` tags. %>
      <div class="group relative flex h-full min-h-0 flex-col bg-surface-container-lowest rounded-lg border border-outline-variant p-lg hover:border-primary transition-colors">
        <%= link_to "", site_path(site),
                    class: "absolute inset-0 rounded-lg",
                    aria: { label: site.name } %>

        <%= render "shared/card_title_and_status", title: site.name %>

        <% unless Current.in_view_as? %>
          <div class="mt-auto pt-md flex justify-end">
            <%= link_to "Edit Site", edit_site_path(site),
                        class: "relative z-10 inline-flex items-center gap-xs rounded-md border border-outline-variant bg-surface-container-lowest px-sm py-1 text-label-sm text-on-surface hover:bg-surface-container",
                        aria: { label: "Edit #{site.name}" } %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
