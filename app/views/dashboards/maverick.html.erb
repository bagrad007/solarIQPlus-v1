<% provide(:title, "Partners — SolarIQ+") %>

<%= render "shared/page_header",
           title: "Partners",
           subtitle: "Status of every Partner across the Maverick network." %>

<% if @partner_summaries.empty? %>
  <div class="bg-surface-container-low border border-outline-variant rounded-lg p-xl text-center text-on-surface-variant">
    No Partners yet. Seed data or create one in the console.
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 2xl:grid-cols-3 gap-lg">
    <% @partner_summaries.each do |s| %>
      <div class="flex h-full min-h-0 flex-col bg-surface-container-lowest rounded-lg border border-outline-variant hover:border-primary transition-colors">
        <%= link_to organization_path(s[:org]), class: "flex min-h-0 flex-1 flex-col p-lg" do %>
          <%= render "shared/card_title_and_status", title: s[:org].name do %>
            <% if s[:critical] > 0 %>
              <span class="inline-flex items-center whitespace-nowrap px-sm py-1 rounded-full bg-error-container text-on-error-container text-label-sm"><%= s[:critical] %> critical</span>
            <% elsif s[:warn] > 0 %>
              <span class="inline-flex items-center whitespace-nowrap px-sm py-1 rounded-full bg-secondary-container text-on-secondary-container text-label-sm"><%= s[:warn] %> warn</span>
            <% else %>
              <span class="inline-flex items-center whitespace-nowrap px-sm py-1 rounded-full bg-primary-fixed text-on-primary-fixed-variant text-label-sm">healthy</span>
            <% end %>
          <% end %>
          <dl class="grid grid-cols-3 gap-x-md gap-y-sm text-center min-w-0">
            <div>
              <dt class="text-label-sm text-on-surface-variant uppercase">Customers</dt>
              <dd class="text-headline-md mt-xs"><%= s[:customer_count] %></dd>
            </div>
            <div>
              <dt class="text-label-sm text-on-surface-variant uppercase">Open cases</dt>
              <dd class="text-headline-md mt-xs"><%= s[:open_cases] %></dd>
            </div>
            <div>
              <dt class="text-label-sm text-on-surface-variant uppercase">Critical/24h</dt>
              <dd class="text-headline-md mt-xs"><%= s[:critical] %></dd>
            </div>
          </dl>
        <% end %>
        <% if current_user.maverick_admin? %>
          <div class="px-lg py-md border-t border-outline-variant flex justify-end">
            <%= button_to "View as #{s[:org].name}",
                          admin_view_as_path(org_id: s[:org].id),
                          method: :post,
                          class: "text-label-sm text-primary hover:underline cursor-pointer",
                          form: { class: "inline" } %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
