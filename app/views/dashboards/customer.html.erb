<% provide(:title, "#{@effective_org.name} — Sites") %>

<%
  actions = capture do
    unless Current.in_view_as?
      concat(link_to "Add Site", new_site_path,
             class: "px-md py-sm rounded-md bg-primary text-on-primary text-label-md hover:opacity-90 inline-flex items-center gap-xs")
    end
  end
%>

<%= render "shared/page_header",
           title: @effective_org.name,
           subtitle: "Operational status of every Site in your fleet.",
           actions: actions %>

<% if @site_summaries.empty? %>
  <div class="bg-surface-container-low border border-outline-variant rounded-lg p-xl text-center text-on-surface-variant">
    No Sites yet. <%= link_to "Add a Site", new_site_path, class: "text-primary underline" unless Current.in_view_as? %>
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-md">
    <% @site_summaries.each do |s| %>
      <%= link_to site_path(s[:site]), class: "block bg-surface-container-lowest rounded-lg border border-outline-variant p-md hover:border-primary transition-colors" do %>
        <div class="flex items-center justify-between mb-md">
          <h3 class="text-headline-md text-on-surface"><%= s[:site].name %></h3>
          <% latest = s[:latest] %>
          <% case latest&.alarm_state %>
          <% when "critical" %>
            <span class="px-sm py-1 rounded-full bg-error-container text-on-error-container text-label-sm">critical</span>
          <% when "warn" %>
            <span class="px-sm py-1 rounded-full bg-secondary-container text-on-secondary-container text-label-sm">warn</span>
          <% when "normal" %>
            <span class="px-sm py-1 rounded-full bg-primary-fixed text-on-primary-fixed-variant text-label-sm">normal</span>
          <% else %>
            <span class="px-sm py-1 rounded-full bg-surface-container-high text-on-surface-variant text-label-sm">no data</span>
          <% end %>
        </div>
        <p class="text-label-sm text-on-surface-variant">
          Polling every <%= s[:site].polling_interval_seconds %>s
          <% if s[:latest] %>
            • last reading <%= time_ago_in_words(s[:latest].recorded_at) %> ago
          <% end %>
        </p>
      <% end %>
    <% end %>
  </div>
<% end %>
